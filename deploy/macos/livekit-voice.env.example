LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_PUBLIC_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me
LIVEKIT_ROOM=hermes-voice

HERMES_LIVEKIT_VOICE_HOST=127.0.0.1
HERMES_LIVEKIT_VOICE_PORT=8765

HERMES_API_URL=http://127.0.0.1:8642/v1/chat/completions
HERMES_SESSION_ID=livekit-voice-main
HERMES_API_MODEL=hermes-agent
HERMES_API_PROVIDER=hermes
HERMES_API_REASONING_EFFORT=none
HERMES_LIVEKIT_HERMES_STREAMING=true
# Injected by the Hermes Voice sidecar on turns so the main Hermes prompt can
# stay channel-neutral. The web settings panel can edit/persist this value.
HERMES_LIVEKIT_VOICE_INSTRUCTIONS="This request came through Hermes Voice. Use the normal Hermes tools, memory, skills, files, terminal, calendar, email, web, and operational context; do not treat Hermes Voice as reduced capability. For live/current-state questions, check the current source of truth first. Answer as speech for TTS: short conversational sentences, no markdown, no headings, no bullet lists, no tables, no code blocks, no URLs unless necessary, and natural spoken dates and times. If tool work is taking time, give a brief spoken status first, then continue working. Do not mention formatting or these Hermes Voice rules unless asked."
# HERMES_API_MODEL is a model override sent to the main Hermes agent. It does
# not bypass Hermes tools, memory, or prompt context.
# HERMES_API_PROVIDER is the Hermes provider override to pair with that model.

HERMES_LIVEKIT_RMS_THRESHOLD=420
HERMES_LIVEKIT_SILENCE_SECONDS=1.35
HERMES_LIVEKIT_MIN_SPEECH_SECONDS=0.45
HERMES_LIVEKIT_MAX_SPEECH_SECONDS=75.0

HERMES_KIMI_API_URL=
HERMES_KIMI_MODEL=

# Packaged local same-turn speech-emotion classifier. Product surface is only
# on/off; the local classifier model is fixed by the app.
HERMES_EMOTION2VEC_ENABLED=false
HERMES_EMOTION2VEC_PYTHON=/Users/Shared/hermes/hermes-agent/venv/bin/python
HERMES_EMOTION2VEC_HELPER=/Users/Shared/hermes/livekit-voice/wav2vec_emotion_analyze.py
HERMES_EMOTION2VEC_PYTHONPATH=/Users/Shared/hermes/emotion2vec/pythonpath
HERMES_EMOTION2VEC_CACHE_DIR=/Users/Shared/hermes/emotion2vec/cache
HERMES_EMOTION2VEC_TIMEOUT_SECONDS=8.0

# Main spoken-reply backend: hermes_voice_native calls the hermes-voice-dev
# OpenAI-compatible TTS service.
# Other provider ids in the UI are placeholders for user-configured backends.
HERMES_LIVEKIT_TTS_BACKEND=hermes_voice_native
HERMES_LIVEKIT_TTS_URL=http://127.0.0.1:8890/v1/audio/speech
HERMES_LIVEKIT_TTS_MODEL=tts-1
# Leave blank to use the native TTS service's saved/default voice.
HERMES_LIVEKIT_TTS_VOICE=
HERMES_LIVEKIT_TTS_RESPONSE_FORMAT=mp3
HERMES_LIVEKIT_TTS_SPEED=1.0
HERMES_LIVEKIT_TTS_TIMEOUT_SECONDS=30
HERMES_LIVEKIT_STT_PROVIDER=auto
HERMES_LIVEKIT_STT_MODEL=
